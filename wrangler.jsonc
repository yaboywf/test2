{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-app",
  "compatibility_date": "2026-03-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "dist/server/ssr/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "images": {
    "binding": "IMAGES"
  }
}
